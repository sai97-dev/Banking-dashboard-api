# ========================
# Banking Dashboard API
# Environment Variables
# ========================

# Node Environment
NODE_ENV=development

# Auth
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# OAuth 2.0
OAUTH_CLIENT_ID=your_oauth_client_id
OAUTH_CLIENT_SECRET=your_oauth_client_secret
OAUTH_CALLBACK_URL=http://localhost:3000/auth/callback
OAUTH_ISSUER_URL=https://your-identity-provider.com

# Services
ACCOUNT_SERVICE_PORT=3001
PAYMENT_SERVICE_PORT=3002
NOTIFICATION_SERVICE_PORT=3003
ALLOWED_ORIGINS=http://localhost:3000

# PostgreSQL
POSTGRES_URI=postgresql://banking_user:banking_pass@localhost:5432/banking_db
POSTGRES_MAX_POOL=20

# Redis
REDIS_URL=redis://localhost:6379

# Kafka
KAFKA_BROKER=localhost:9092
KAFKA_GROUP_ID=banking-consumer-group

# AWS
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
S3_BUCKET_NAME=banking-assets-bucket

# Monitoring
LOG_LEVEL=info
